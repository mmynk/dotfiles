#!/usr/bin/env bash

set -e

OS_TYPE=$(uname -s)

# Set the appropriate sed function based on OS
if [[ "$OS_TYPE" == "Darwin" ]]; then
    sed_cmd() { sed -i '' "s|$1|$2|g" "$3"; }
else
    sed_cmd() { sed -i "s|$1|$2|g" "$3"; }
fi

replace_string() {
    sed_cmd "$1" "$2" "$3"
}

replace_user() {
    replace_string "<username>" "$USER" "$1"
}

safe_copy() {
    if [ ! -f "$2" ]; then
        cp "$1" "$2"
    fi
}

install_nix() {
    if command -v nix > /dev/null; then
        echo "nix already installed, skipping..."
    else
        echo "Installing nix..."
        sh <(curl -L https://nixos.org/nix/install) --daemon
    fi
}

setup_fish() {
    echo "Setting up fish..."

    # Symlink fish config and aliases
    mkdir -p ~/.config/fish
    ln -sf "$(pwd)/shell/config.fish" ~/.config/fish/config.fish
    ln -sf "$(pwd)/shell/fish_plugins" ~/.config/fish/fish_plugins
    ln -sf "$(pwd)/shell/aliases.fish" ~/.aliases.fish
    ln -sf "$(pwd)/config/starship.toml" ~/.config/starship.toml

    # Install fisher and all plugins from fish_plugins
    echo "Installing fish plugins..."
    fish -c "curl -sL https://raw.githubusercontent.com/jorgebucaran/fisher/main/functions/fisher.fish | source && fisher update"

    # Seed extra_aliases from OS-specific template
    case "$OS_TYPE" in
        Linux*)     safe_copy ./shell/extra_aliases_linux.fish ~/.extra_aliases.fish ;;
        Darwin*)    safe_copy ./shell/extra_aliases_darwin.fish ~/.extra_aliases.fish ;;
    esac
}

setup_tmux() {
    echo "Setting up tmux..."
    mkdir -p ~/.config/tmux
    safe_copy ./config/tmux.conf ~/.config/tmux/tmux.conf

    # Install TPM if not present
    if [ ! -d ~/.tmux/plugins/tpm ]; then
        echo "Installing TPM..."
        git clone https://github.com/tmux-plugins/tpm ~/.tmux/plugins/tpm
    fi
}

install_linux() {
    install_nix

    echo "Setting up nix home-manager..."
    mkdir -p ~/.config/nix/home-manager

    safe_copy ./nix.conf ~/.config/nix/nix.conf
    safe_copy ./linux/flake.nix ~/.config/nix/flake.nix
    safe_copy ./linux/home.nix ~/.config/nix/home-manager/home.nix

    replace_string "<pwd>" "$(pwd)" ~/.config/nix/home-manager/home.nix
    replace_user ~/.config/nix/flake.nix
    replace_user ~/.config/nix/home-manager/home.nix

    echo "Building home-manager configuration..."
    nix run nixpkgs#home-manager -- switch --flake ~/.config/nix

    setup_fish
    setup_tmux
}

install_mac() {
    install_nix

    echo "Setting up nix-darwin..."
    mkdir -p ~/.config/nix

    safe_copy ./nix.conf ~/.config/nix/nix.conf
    safe_copy ./darwin/flake.nix ~/.config/nix/flake.nix

    replace_user ~/.config/nix/flake.nix

    echo "Building darwin configuration..."
    sudo nix run nix-darwin/master#darwin-rebuild -- switch --flake ~/.config/nix#$USER

    setup_fish
    setup_tmux
}

case "$OS_TYPE" in
    Linux*)     install_linux ;;
    Darwin*)    install_mac ;;
    *)          echo "Unsupported OS: $OS_TYPE" ;;
esac

echo ""
echo "Installation complete!"
echo "Open tmux and press prefix + I to install tmux plugins."
