#!/usr/bin/env bash

set -e

OS_TYPE=$(uname -s)

# Set the appropriate sed function based on OS
if [[ "$OS_TYPE" == "Darwin" ]]; then
    sed_cmd() { sed -i '' "s|$1|$2|g" "$3"; }
else
    sed_cmd() { sed -i "s|$1|$2|g" "$3"; }
fi

replace_string() {
    sed_cmd "$1" "$2" "$3"
}

replace_user() {
    replace_string "<username>" "$USER" "$1"
}

replace_system() {
    # Resolve the nix system string (e.g. aarch64-linux, x86_64-linux) at install
    # time. builtins.currentSystem is impure, so it cannot live inside the flake —
    # we detect it here and substitute the <system> placeholder.
    local sys
    sys=$(nix eval --impure --raw --expr 'builtins.currentSystem')
    replace_string "<system>" "$sys" "$1"
}

render() {
    # For generated files (flake.nix, home.nix) that get sed-substituted: always
    # overwrite from the repo so a repo change reaches the deployed copy on re-run.
    cp -f "$1" "$2"
}

install_nix() {
    if command -v nix > /dev/null; then
        echo "nix already installed, skipping..."
    else
        echo "Installing nix..."
        sh <(curl -L https://nixos.org/nix/install) --daemon
    fi
}

setup_fish() {
    echo "Setting up fish..."

    # Symlink fish config and aliases
    mkdir -p ~/.config/fish
    ln -sf "$(pwd)/shell/config.fish" ~/.config/fish/config.fish
    ln -sf "$(pwd)/shell/fish_plugins" ~/.config/fish/fish_plugins
    ln -sf "$(pwd)/shell/aliases.fish" ~/.aliases.fish
    ln -sf "$(pwd)/config/starship.toml" ~/.config/starship.toml

    # Install fisher and all plugins from fish_plugins
    echo "Installing fish plugins..."
    fish -c "curl -sL https://raw.githubusercontent.com/jorgebucaran/fisher/main/functions/fisher.fish | source && fisher update"
}

setup_nvim() {
    echo "Setting up nvim..."
    ln -sf "$(pwd)/config/nvim" ~/.config/nvim
}

setup_tmux() {
    echo "Setting up tmux..."
    mkdir -p ~/.config/tmux
    ln -sf "$(pwd)/config/tmux.conf" ~/.config/tmux/tmux.conf

    # Install TPM if not present
    if [ ! -d ~/.tmux/plugins/tpm ]; then
        echo "Installing TPM..."
        git clone https://github.com/tmux-plugins/tpm ~/.tmux/plugins/tpm
    fi
}

setup_git() {
    echo "Setting up git..."
    mkdir -p ~/.config/git
    ln -sf "$(pwd)/config/git/config" ~/.config/git/config
    ln -sf "$(pwd)/config/git/excludes" ~/.config/git/excludes
}

setup_claude() {
    echo "Setting up claude..."
    mkdir -p ~/.claude/skills

    # Harness-agnostic agent instructions. Claude Code reads ~/.claude/CLAUDE.md;
    # the source file is named AGENTS.md so the same file can be symlinked to other
    # harnesses' expected paths. Employer/machine-local rules are pulled in by the
    # @import at the bottom of AGENTS.md, which resolves into the gitignored
    # internal/ dir only on machines that have it.
    ln -sf "$(pwd)/config/ai/AGENTS.md" ~/.claude/CLAUDE.md

    # Skills: symlink each so edits stay live. Remove any existing entry first —
    # ln -sf won't replace a real directory (it would nest the link inside it),
    # so an existing skill dir must be cleared before relinking.
    for skill in config/ai/skills/*/; do
        name="$(basename "$skill")"
        rm -rf ~/.claude/skills/"$name"
        ln -sfn "$(pwd)/${skill%/}" ~/.claude/skills/"$name"
    done
}

setup_common() {
    setup_fish
    setup_nvim
    setup_tmux
    setup_git
    setup_claude
}

install_linux() {
    install_nix

    echo "Setting up nix home-manager..."
    mkdir -p ~/.config/nix/home-manager

    mkdir -p ~/.config/nix && ln -sf "$(pwd)/nix.conf" ~/.config/nix/nix.conf
    render ./linux/flake.nix ~/.config/nix/flake.nix
    render ./linux/home.nix ~/.config/nix/home-manager/home.nix

    replace_string "<pwd>" "$(pwd)" ~/.config/nix/home-manager/home.nix
    replace_user ~/.config/nix/flake.nix
    replace_user ~/.config/nix/home-manager/home.nix
    replace_system ~/.config/nix/flake.nix

    echo "Building home-manager configuration..."
    nix run nixpkgs#home-manager -- switch --flake ~/.config/nix

    setup_common
}

install_mac() {
    install_nix

    echo "Setting up nix-darwin..."
    mkdir -p ~/.config/nix

    mkdir -p ~/.config/nix && ln -sf "$(pwd)/nix.conf" ~/.config/nix/nix.conf
    render ./darwin/flake.nix ~/.config/nix/flake.nix

    replace_user ~/.config/nix/flake.nix

    echo "Building darwin configuration..."
    sudo nix run nix-darwin/master#darwin-rebuild -- switch --flake ~/.config/nix#$USER

    setup_common
}

# Run internal tooling if it exists
if [ -f ./internal/install ]; then
    . ./internal/install
fi

case "$OS_TYPE" in
    Linux*)     install_linux ;;
    Darwin*)    install_mac ;;
    *)          echo "Unsupported OS: $OS_TYPE" ;;
esac

echo ""
echo "Installation complete!"
echo "Open tmux and press prefix + I to install tmux plugins."
echo ""
echo "If fish is not your default shell:"
echo "  echo \$(which fish) | sudo tee -a /etc/shells"
echo "  chsh -s \$(which fish)"
